rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──────────────────────────────────────────────────
    match /users/{userId} {
      // Public read — needed for username uniqueness check during signup
      allow read: if true;

      // Only the user themselves can create their own doc
      allow create: if request.auth != null && request.auth.uid == userId;

      // The user can update their own doc freely.
      // Other authenticated users can update ONLY aggregate stat fields
      // (needed for approveGame to increment the game owner's stats).
      allow update: if request.auth != null && (
        request.auth.uid == userId ||
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['totalCaps', 'totalGames', 'totalWins', 'totalLosses',
                    'currentWinStreak', 'bestWinStreak', 'expoPushToken'])
      );

      // Only the user themselves can delete their own doc
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // ── Games ──────────────────────────────────────────────────
    match /games/{gameId} {
      // Any signed-in user can read games (needed for leaderboard + achievements)
      allow read: if request.auth != null;

      // Only the game logger can create a game, and they must be in the players list
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId
        && request.auth.uid in request.resource.data.players;

      // The logger or any tagged player can update (for approvals/rejections)
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        request.auth.uid in resource.data.players
      );

      // Only the logger can delete their own pending game
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.userId
        && resource.data.status == 'pending';
    }

    // ── Groups ─────────────────────────────────────────────────
    match /groups/{groupId} {
      // Any signed-in user can read groups (needed to join by invite code)
      allow read: if request.auth != null;

      // Any signed-in user can create a group
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.members;

      // Only current members can update or delete the group
      allow update: if request.auth != null
        && request.auth.uid in resource.data.members;

      allow delete: if request.auth != null
        && request.auth.uid in resource.data.members;
    }
  }
}
